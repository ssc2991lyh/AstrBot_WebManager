{
  "name": "astrbot-launcher",
  "private": true,
  "version": "0.3.9",
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "fe:lint": "eslint src",
    "fe:lint:fix": "eslint src --fix",
    "fe:fmt": "prettier --write \"src/**/*.{ts,tsx}\"",
    "cargo:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "cargo:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets",
    "fmt:all": "pnpm run fe:fmt && pnpm run cargo:fmt",
    "check:all": "pnpm run fe:lint && pnpm run cargo:check"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-log": "~2.9.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "ansi-to-react": "^6.2.6",
    "antd": "^6.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "typescript": "~5.8.3",
    "vite": "^7.3.6"
  }
}
